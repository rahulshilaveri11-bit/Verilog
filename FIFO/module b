module mod_b(
    input clk,rst,input [7:0] data_in,output reg [7:0] data_out,output reg read_enb
    );
    parameter IDLE  = 2'b00;
    parameter S1 = 2'b01;
    parameter data_phase = 2'b10;
    
    reg [1:0] ps,ns;
    
    always @(posedge clk)
      begin
         if(rst)
            ps <= IDLE;
         else 
            ps <= ns;
       end
       
       always @(*) begin
          ns = IDLE;
          read_enb = 0;
          case(ps)
             IDLE : begin
                     ns = S1;
                     read_enb = 0;
                   end
             S1 : begin
                   ns = data_phase;
                  end
             data_phase : begin 
                             ns = IDLE;
                             read_enb = 1;
                          end
             default: ns = IDLE;
             endcase
             end

       always @(posedge clk) begin
          if(rst)
             data_out <= 0;
          else if(read_enb)
             data_out <= data_in;
       end
               
endmodule

module TOP_FIFO_tb(
    );
    reg clk,rst;
    reg [7:0] data_in;
    wire [7:0] data_out;
    
    TOP_FIFO dut(clk,rst,data_in,data_out);
    
    initial begin
       {clk,rst,data_in} = 0;
    end
    
    always #5 clk = ~clk;
    
    initial begin 
        rst = 1;
        #10;
        rst = 0;
        #10;
        data_in = 3;
        #10;
        data_in= 6;
        #10;
        data_in = 9;
        #10;
        $finish;
        end
        
           
endmodule

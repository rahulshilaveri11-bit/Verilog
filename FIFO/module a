module mod_a(
    input clk,rst,input [7:0] data_in,output reg [7:0] data_out,output reg write_enb
    );
    always @(posedge clk) begin
      if (rst)  begin
         data_out <= 0;
         write_enb <=0;
         end
      else begin
        data_out <= data_in;
        write_enb <= 1;
        end
     end
           
endmodule

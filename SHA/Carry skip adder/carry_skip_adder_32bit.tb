module carry_skip_adder_32bit_tb;

    reg  [31:0] a,b;
    reg         cin;

    wire [31:0] sum;
    wire        cout;

    carry_skip_adder_32bit uut (
        .a(a),
        .b(b),
        .cin(cin),
        .sum(sum),
        .cout(cout)
    );

    // Test Cases
    initial begin

        // Test 1
        a   = 32'b00000000000000000000000000000000;
        b   = 32'b00000000000000000000000000000000;
        cin = 1'b0;

        // Test 2
        #10;
        a   = 32'b00000000000000000000000000000101;
        b   = 32'b00000000000000000000000000000101;
        cin = 1'b1;

        // Test 3
        #10;
        a   = 32'b00000000000000000000000000011111;
        b   = 32'b00000000000000000000000000011100;
        cin = 1'b0;

        // Test 4
        #10;
        a   = 32'b11000110000111110000111100001111;
        b   = 32'b00000011000110000001100000011000;
        cin = 1'b1;

        // Test 5
        #10;
        a   = 32'b11111111111111111111111111111111;
        b   = 32'b00000000000000000000000000000000;
        cin = 1'b1;

        // Test 6
        #10;
        a   = 32'b00000000000000000000000000000001;
        b   = 32'b00000000000000000000000000000001;
        cin = 1'b1;

        // Test 7
        #10;
        a   = 32'b00000000000000000000000000000010;
        b   = 32'b00000000000000000000000000000010;
        cin = 1'b1;

        // Test 8
        #10;
        a   = 32'h12345678;
        b   = 32'h87654321;
        cin = 1'b0;

        // Test 9
        #10;
        a   = 32'hAAAAAAAA;
        b   = 32'h55555555;
        cin = 1'b1;

        // Test 10
        #10;
        a   = 32'hFFFFFFFF;
        b   = 32'hFFFFFFFF;
        cin = 1'b0;

        #10;
        $finish;

    end
endmodule
